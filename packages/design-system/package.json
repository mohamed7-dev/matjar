{
	"name": "@matjar/design-system",
	"private": true,
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/theme-tokens/index.d.ts",
			"default": "./dist/theme-tokens/index.js"
		},
		"./components/*": "./src/shadcn/components/*.tsx",
		"./hooks/*": "./src/shadcn/hooks/*.ts",
		"./lib/*": "./src/shadcn/lib/*.ts",
		"./globals.css": "./src/shadcn/globals.css"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "rimraf dist && tsc --project ./tsconfig.build.json",
		"lint": "biome check src/ --write",
		"check-types": "tsc --noEmit"
	},
	"dependencies": {
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"lucide-react": "^1.18.0",
		"radix-ui": "^1.5.0",
		"react": "^19.2.6",
		"react-dom": "^19.2.6",
		"shadcn": "^4.11.0",
		"tailwind-merge": "^3.6.0",
		"tw-animate-css": "^1.4.0"
	},
	"devDependencies": {
		"rimraf": "^6.1.3",
		"@types/node": "^22",
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"tailwindcss": "^4",
		"@tailwindcss/vite": "^4"
	}
}
