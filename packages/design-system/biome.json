{
	"$schema": "../../node_modules/@biomejs/biome/configuration_schema.json",
	"extends": [
		"../../biome.json"
	],
	"root": false,
	"vcs": {
		"enabled": false,
		"clientKind": "git",
		"useIgnoreFile": false,
		"root": "../../"
	},
	"files": {
		"ignoreUnknown": true,
		"includes": [
			"**/*.{ts,tsx,json,css,html}"
		]
	},
	"linter": {
		"rules": {
			"suspicious": {
				"noArrayIndexKey": "off"
			},
			"a11y": {
				"useSemanticElements": "off"
			}
		}
	}
}
