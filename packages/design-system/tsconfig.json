{
	"$schema": "https://www.schemastore.org/tsconfig",
	"compilerOptions": {
		"target": "ES2020",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"lib": [
			"ES2020",
			"DOM",
			"DOM.Iterable"
		],
		"skipLibCheck": true,
		"jsx": "react-jsx",
		"strict": true,
		"declaration": true,
		"sourceMap": true,
		"paths": {
			"@matjar/design-system/*": [
				"./src/shadcn/*"
			]
		}
	}
}
