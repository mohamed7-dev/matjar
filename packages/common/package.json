{
	"name": "@matjar/common",
	"private": true,
	"type": "module",
	"main": "index.js",
	"exports": {
		".": "./lib/index.js",
		"./lib/*": "./lib/*.js"
	},
	"files": [
		"lib/**/*"
	],
