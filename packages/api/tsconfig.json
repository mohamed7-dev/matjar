{
	"$schema": "https://www.schemastore.org/tsconfig",
	"extends": "../../tsconfig.json",
	"compilerOptions": {
		"declaration": true,
		"declarationMap": true,

		"strictPropertyInitialization": false,
		"emitDecoratorMetadata": true,
		"experimentalDecorators": true,

		"sourceMap": true,
		"removeComments": true
	}
}
