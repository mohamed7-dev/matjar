{
	"$schema": "https://json.schemastore.org/nest-cli",
	"collection": "@nestjs/schematics",
	"sourceRoot": "src",
	"compilerOptions": {
		"deleteOutDir": true,
		"assets": [
			{
				"watchAssets": true,
				"include": "**/*.graphql"
			},
			{
				"watchAssets": true,
				"include": "i18n/locales/*.json"
			}
		]
	}
}
